---
interface Props {
  /** Unique prefix so field ids stay unique if the form appears twice on a page. */
  idPrefix?: string;
}
const { idPrefix = "req" } = Astro.props;
---

<!-- Anfrage-Formular -->
<div class="border border-line bg-ink-2 shadow-[0_24px_50px_rgba(0,0,0,0.5)]">
  <div class="flex items-center justify-between border-b border-line bg-ink-3 px-[18px] py-[13px]">
    <div class="font-mono text-[10px] tracking-[.12em] text-dim-2">GRATIS-PAKET ANFORDERN · IN 24H</div>
    <div class="font-mono text-[10px] text-lime">● BEREIT</div>
  </div>
  <form
    action="https://api.web3forms.com/submit"
    method="post"
    data-web3form
    class="flex flex-col gap-[18px] p-5 md:p-[26px]"
  >
    <input type="hidden" name="access_key" value={import.meta.env.PUBLIC_WEB3FORMS_KEY} />
    <input type="hidden" name="subject" value="Neue Marketingpaket-Anfrage über die Website" />
    <input type="hidden" name="from_name" value="Immersive Markets Website" />
    <input type="hidden" name="redirect" value="https://immersive-markets.de/vorschau/danke" />
    <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />
    <div>
      <label for={`${idPrefix}-firma`} class="mb-2 block font-mono text-[11px] tracking-wider text-dim-2">
        FIRMEN-URL *
      </label>
      <input
        id={`${idPrefix}-firma`}
        name="firma"
        required
        placeholder="mustermann-gmbh.de"
        class="w-full border border-line bg-ink-3 px-4 py-3.5 text-[15px] text-bone placeholder:text-dim focus:border-lime focus:outline-none"
      />
    </div>

    <div>
      <label for={`${idPrefix}-email`} class="mb-2 block font-mono text-[11px] tracking-wider text-dim-2">
        E-MAIL *
      </label>
      <input
        id={`${idPrefix}-email`}
        name="email"
        type="email"
        required
        placeholder="name@firma.de"
        class="w-full border border-line bg-ink-3 px-4 py-3.5 text-[15px] text-bone placeholder:text-dim focus:border-lime focus:outline-none"
      />
    </div>

    <label class="flex cursor-pointer items-start gap-3 text-[12px] leading-[1.5] text-dim-2">
      <input
        type="checkbox"
        name="dsgvo"
        required
        class="mt-0.5 size-4 shrink-0 accent-[color:var(--color-lime)]"
      />
      <span>
        Ich habe die <a href="/datenschutz" class="text-lime underline-offset-2 hover:underline">Datenschutzerklärung</a>
        gelesen und bin mit der Verarbeitung meiner Daten einverstanden.
      </span>
    </label>

    <label class="flex cursor-pointer items-start gap-3 text-[12px] leading-[1.5] text-dim-2">
      <input
        type="checkbox"
        name="ki"
        required
        class="mt-0.5 size-4 shrink-0 accent-[color:var(--color-lime)]"
      />
      <span>
        Ich willige in KI-gestützte Verarbeitung zur Erstellung des Pakets ein
        (transparent gem. Art.&nbsp;50 EU-KI-VO).
      </span>
    </label>

    <button
      type="submit"
      class="cursor-pointer bg-lime px-4 py-4 text-center font-mono text-[13px] font-medium text-ink transition-colors hover:bg-bone"
    >
      Kostenloses Marketingpaket anfordern →
    </button>
  </form>
</div>
