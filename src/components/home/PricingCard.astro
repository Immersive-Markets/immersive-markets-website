---
const tiers = [
  {
    name: "Kostenlose Erstellung",
    price: "0 €",
    unit: "einmalig",
    note: "Ihr komplettes Marketingpaket zum Kennenlernen — individuell erstellt, unverbindlich.",
    features: [
      "Vollständiges Marketingkonzept",
      "Fertige Musterbeiträge, Flyer & Visitenkarten",
      "SEO- & KI-Sichtbarkeits-Check",
      "In 24 Stunden, ohne Setup-Fee",
    ],
    cta: "Gratis-Paket anfordern →",
    featured: false,
  },
  {
    name: "Komplette Online-Marketing-Betreuung",
    price: "990 €",
    unit: "/ Monat",
    note: "Ihr komplettes digitales Marketing über alle Kanäle, jeden Monat verlässlich geliefert.",
    features: [
      "Alle digitalen Deliverables aus dem Abo",
      "Fester Ansprechpartner, durchgehend erreichbar",
      "Volle Transparenz & Freigabe vor jedem Beitrag",
      "Monats-Report, keine Setup-Fee, monatlich kündbar",
    ],
    cta: "Erst das Paket sehen →",
    featured: true,
  },
  {
    name: "Full Service inkl. Druck & Design",
    price: "1.990 €",
    unit: "/ Monat",
    note: "Alles aus der Online-Betreuung — plus Druck- & Design-Flatrate für Ihre Offline-Präsenz.",
    features: [
      "Alles aus der Online-Marketing-Betreuung",
      "Druck- & Design-Flatrate",
      "Flyer, Broschüren & Visitenkarten",
      "Druckfertige Vorlagen für Ihre CI",
    ],
    cta: "Erst das Paket sehen →",
    featured: false,
  },
];
---

<section id="preis" class="bg-bone px-5 py-16 text-ink md:px-12 md:py-[88px]">
  <div class="mx-auto max-w-[1240px]">
    <div class="mb-11 text-center">
      <div class="mb-3.5 font-mono text-[12px] uppercase tracking-[.16em] text-dim">Ein Paket, ein Preis</div>
      <h2 class="m-0 font-display text-[30px] leading-[0.95] font-black uppercase -tracking-[0.02em] sm:text-4xl md:text-[42px]">
        Eine ganze Marketing-Abteilung.<br />
        <span class="bg-lime px-[8px] text-ink">Zum Minijob-Preis.</span>
      </h2>
      <p class="mx-auto mt-5 max-w-[520px] font-display text-[18px] font-bold uppercase -tracking-[0.01em] text-ink/70 md:text-[22px]">
        Fester Monatspreis. Monatlich kündbar.
      </p>
    </div>

    <div class="grid items-stretch gap-6 md:grid-cols-3">
      {tiers.map((tier) => (
        <div
          class:list={[
            "relative flex flex-col p-8 md:p-9",
            tier.featured
              ? "bg-ink text-bone ring-2 ring-lime md:-my-3 md:py-12"
              : "border border-ink/15 bg-bone text-ink",
          ]}
        >
          {tier.featured && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-lime px-3 py-1 font-mono text-[10px] font-bold uppercase tracking-[.12em] text-ink">
              ★ Sehr beliebt
            </div>
          )}
          <div class:list={["mb-4 font-mono text-[11px] tracking-[.12em]", tier.featured ? "text-lime" : "text-dim"]}>
            {tier.name}
          </div>
          <div class="flex items-end gap-2">
            <span class="font-display text-[44px] leading-[0.85] font-black -tracking-[0.03em] md:text-[52px]">
              {tier.price}
            </span>
            <span class:list={["pb-2 font-mono text-[12px]", tier.featured ? "text-dim" : "text-dim"]}>
              {tier.unit}
            </span>
          </div>
          <p class:list={["mt-5 text-[14px] leading-relaxed", tier.featured ? "text-dim-2" : "text-ink/65"]}>
            {tier.note}
          </p>
          <ul class:list={["mt-6 flex flex-col gap-3 text-[14px]", tier.featured ? "text-bone" : "text-ink"]}>
            {tier.features.map((f) => (
              <li class="flex gap-2.5"><span class="text-lime">✓</span>{f}</li>
            ))}
          </ul>
          <a
            href="/vorschau"
            class:list={[
              "mt-auto cursor-pointer px-6 py-4 text-center font-mono text-[13px] font-medium transition-colors",
              tier.featured
                ? "bg-lime text-ink hover:bg-bone"
                : "border border-ink text-ink hover:bg-ink hover:text-bone",
            ]}
          >
            {tier.cta}
          </a>
        </div>
      ))}
    </div>

    <p class="mt-8 text-center font-mono text-[11px] leading-relaxed text-dim">
      Preise als Kleinunternehmer gem. §19 UStG, keine USt. · Sonderfälle mit hohem Volumen besprechen wir individuell.
    </p>
  </div>
</section>
