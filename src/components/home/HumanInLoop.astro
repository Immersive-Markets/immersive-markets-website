---
const columns = [
  {
    tag: "DIE KI MACHT",
    tagClass: "text-dim",
    title: "Die Fleißarbeit",
    items: ["Recherche & Themenideen", "Erste Entwürfe & Varianten", "Grafik-Rohlinge, Zeitplanung"],
    bg: "",
    text: "text-dim-2",
  },
  {
    tag: "DER MENSCH MACHT",
    tagClass: "text-lime",
    title: "Die Entscheidung",
    items: ["Auswahl & Freigabe", "Feinschliff & Tonalität", "Fakten- & Marken-Check"],
    bg: "bg-ink-2 border-x border-line",
    text: "text-bone",
  },
  {
    tag: "SIE BEKOMMEN",
    tagClass: "text-dim",
    title: "Die Kontrolle",
    items: ["Finale Freigabe bei Ihnen", "Alle Rechte, alle Dateien", "Nichts erscheint ohne Ihr OK"],
    bg: "",
    text: "text-dim-2",
  },
];
---

<section class="imgrid border-t border-line px-5 py-16 md:px-12 md:py-[88px]">
  <div class="mx-auto max-w-[1240px]">
    <div class="mb-10 md:mb-[52px]">
      <div class="mb-3.5 font-mono text-[12px] uppercase tracking-[.16em] text-lime">
        Wie KI und Mensch zusammenspielen
      </div>
      <h2
        class="m-0 max-w-[820px] font-display text-[30px] leading-[0.95] font-black uppercase -tracking-[0.02em] sm:text-4xl md:text-[42px]"
      >
        Nichts geht ungeprüft raus.
      </h2>
    </div>

    <div class="grid border border-line md:grid-cols-3">
      {columns.map((c, i) => (
        <div class:list={[
          "relative p-8",
          c.bg,
          i < columns.length - 1 ? "border-b border-line md:border-b-0" : "",
        ]}>
          <div class:list={["mb-4 font-mono text-[11px] tracking-widest", c.tagClass]}>{c.tag}</div>
          <div class="mb-3.5 text-[20px] font-bold text-bone">{c.title}</div>
          <ul class:list={["flex flex-col gap-2.5 text-sm leading-[1.5]", c.text]}>
            {c.items.map((item) => <li>{item}</li>)}
          </ul>
          {i < columns.length - 1 && (
            <span class="pointer-events-none absolute -bottom-3 left-1/2 hidden -translate-x-1/2 rotate-90 font-mono text-[24px] text-line-deep md:top-1/2 md:right-[-12px] md:bottom-auto md:left-auto md:block md:-translate-y-1/2 md:rotate-0">
              →
            </span>
          )}
        </div>
      ))}
    </div>

    <div class="mt-7 flex max-w-[820px] flex-wrap items-start gap-3.5 border border-line px-6 py-5">
      <span class="whitespace-nowrap pt-0.5 font-mono text-[10px] tracking-widest text-lime">EU AI ACT</span>
      <p class="m-0 flex-1 text-sm leading-relaxed text-dim-2">
        KI-Einsatz wird transparent gekennzeichnet — so, wie es Art.&nbsp;50 der EU-KI-Verordnung ab dem 02.08.2026
        vorschreibt. Kein Blackbox-Tool, keine versteckte Automatisierung.
      </p>
    </div>
  </div>
</section>
