---
const forYou = [
  "Sie brauchen Marketing, haben aber weder Zeit noch ein Team dafür.",
  "Sie wollen einen festen Monatspreis — keine Beratertage, keine Setup-Fee.",
  "Sie wollen das Ergebnis sehen, bevor Sie sich binden.",
];
const notForYou = [
  "Sie planen eine Großkampagne mit eigenem Budget-Komitee.",
  "Sie wollen jeden Post selbst schreiben und mehrfach umbauen.",
  "Der günstigste Preis zählt für Sie mehr als das Ergebnis.",
];
---

<section class="grid border-t border-line md:grid-cols-2">
  <div class="border-b border-line px-5 py-14 md:border-r md:border-b-0 md:px-12 md:py-14">
    <div class="mx-auto md:mx-0 md:mr-10 md:ml-auto md:max-w-[600px]">
      <div
        class="mb-8 inline-block bg-lime px-3 py-1.5 font-mono text-[11px] uppercase tracking-[.12em] text-ink"
      >
        Für Sie
      </div>
      <ul class="flex flex-col">
        {forYou.map((item, i) => (
          <li
            class:list={[
              "text-base leading-[1.4] font-medium text-bone py-[18px] md:text-[18px]",
              i < forYou.length - 1 ? "border-b border-line" : "pb-0",
            ]}
          >
            {item}
          </li>
        ))}
      </ul>
    </div>
  </div>

  <div class="bg-ink-2 px-5 py-14 md:px-12 md:py-14">
    <div class="mx-auto md:mx-0 md:ml-10 md:mr-auto md:max-w-[600px]">
      <div
        class="mb-8 inline-block border border-line-deep px-3 py-1.5 font-mono text-[11px] uppercase tracking-[.12em] text-dim"
      >
        Nichts für Sie
      </div>
      <ul class="flex flex-col">
        {notForYou.map((item, i) => (
          <li
            class:list={[
              "text-base leading-[1.4] text-dim py-[18px] md:text-[18px]",
              i < notForYou.length - 1 ? "border-b border-line" : "pb-0",
            ]}
          >
            {item}
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
