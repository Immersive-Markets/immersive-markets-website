---
---

<section class="imgrid relative overflow-hidden px-5 pt-14 pb-16 md:px-12 md:pt-[74px] md:pb-16">
  <div class="mx-auto max-w-[1240px]">
    <div
      class="mb-8 flex flex-wrap items-start justify-between gap-3 font-mono text-[11px] uppercase tracking-[.14em] text-[#8b8f78] md:mb-11"
    >
      <span>Kostenlos · KI-gestützt · Sofort</span>
    </div>

    <div class="grid items-start gap-10 md:grid-cols-[1.15fr_1fr] md:gap-12">
      <div>
        <h1
          class="m-0 font-display text-[42px] leading-[0.95] font-black uppercase -tracking-[0.03em] text-bone sm:text-5xl md:text-[60px]"
        >
          Ihr komplettes<br />
          Marketingpaket<br />
          auf Knopfdruck.<br />
          <span class="bg-lime px-[10px] text-ink">100% Kostenlos.</span>
        </h1>
        <ul class="mt-7 flex max-w-[460px] flex-col gap-2.5 text-base leading-[1.4] text-dim-2 md:text-[17px]">
          <li class="flex gap-3"><span class="text-lime">✓</span>Marketingkonzept als Präsentation</li>
          <li class="flex gap-3"><span class="text-lime">✓</span>Fertige Musterbeiträge für Ihre Kanäle</li>
          <li class="flex gap-3"><span class="text-lime">✓</span>Flyer, Briefbogen &amp; Visitenkarten</li>
          <li class="flex gap-3"><span class="text-lime">✓</span>SEO- &amp; KI-Sichtbarkeits-Check</li>
          <li class="flex gap-3"><span class="text-lime">✓</span>Individuell aus Ihrer Website, in 24 Stunden</li>
        </ul>
        <div class="mt-9">
          <a
            href="#funktioniert"
            class="cursor-pointer border-b border-line pb-[3px] font-mono text-[13px] text-bone transition-colors hover:text-lime"
          >
            Wie das läuft →
          </a>
        </div>
      </div>

      <!-- Anfrage-Formular -->
      <div class="border border-line bg-ink-2 shadow-[0_24px_50px_rgba(0,0,0,0.5)]">
        <div class="flex items-center justify-between border-b border-line bg-ink-3 px-[18px] py-[13px]">
          <div class="font-mono text-[10px] tracking-[.12em] text-dim">GRATIS-PAKET ANFORDERN · IN 24H</div>
          <div class="font-mono text-[10px] text-lime">● BEREIT</div>
        </div>
        <form
          action="https://api.web3forms.com/submit"
          method="post"
          data-web3form
          class="flex flex-col gap-[18px] p-5 md:p-[26px]"
        >
          <input type="hidden" name="access_key" value={import.meta.env.PUBLIC_WEB3FORMS_KEY} />
          <input type="hidden" name="subject" value="Neue Marketingpaket-Anfrage über die Website" />
          <input type="hidden" name="from_name" value="Immersive Markets Website" />
          <input type="hidden" name="redirect" value="https://immersive-markets.de/vorschau/danke" />
          <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />
          <div>
            <label for="hero-firma" class="mb-2 block font-mono text-[11px] tracking-wider text-dim">
              FIRMEN-URL *
            </label>
            <input
              id="hero-firma"
              name="firma"
              required
              placeholder="mustermann-gmbh.de"
              class="w-full border border-line bg-ink-3 px-4 py-3.5 text-[15px] text-bone placeholder:text-dim focus:border-lime focus:outline-none"
            />
          </div>

          <div>
            <label for="hero-email" class="mb-2 block font-mono text-[11px] tracking-wider text-dim">
              E-MAIL *
            </label>
            <input
              id="hero-email"
              name="email"
              type="email"
              required
              placeholder="name@firma.de"
              class="w-full border border-line bg-ink-3 px-4 py-3.5 text-[15px] text-bone placeholder:text-dim focus:border-lime focus:outline-none"
            />
          </div>

          <label class="flex cursor-pointer items-start gap-3 text-[12px] leading-[1.5] text-dim-2">
            <input
              type="checkbox"
              name="dsgvo"
              required
              class="mt-0.5 size-4 shrink-0 accent-[color:var(--color-lime)]"
            />
            <span>
              Ich habe die <a href="/datenschutz" class="text-lime underline-offset-2 hover:underline">Datenschutzerklärung</a>
              gelesen und bin mit der Verarbeitung meiner Daten einverstanden.
            </span>
          </label>

          <label class="flex cursor-pointer items-start gap-3 text-[12px] leading-[1.5] text-dim-2">
            <input
              type="checkbox"
              name="ki"
              required
              class="mt-0.5 size-4 shrink-0 accent-[color:var(--color-lime)]"
            />
            <span>
              Ich willige in KI-gestützte Verarbeitung zur Erstellung des Pakets ein
              (transparent gem. Art.&nbsp;50 EU-KI-VO).
            </span>
          </label>

          <button
            type="submit"
            class="cursor-pointer bg-lime px-4 py-4 text-center font-mono text-[13px] font-medium text-ink transition-colors hover:bg-bone"
          >
            Kostenloses Marketingpaket anfordern →
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
