---

<section class="imgrid relative overflow-hidden px-5 pt-14 pb-16 md:px-12 md:pt-[74px] md:pb-16">
  <div class="mx-auto max-w-[1240px]">
    <div
      class="mb-8 flex flex-wrap items-start justify-between gap-3 font-mono text-[11px] uppercase tracking-[.14em] text-[#8b8f78] md:mb-11"
    >
      <span>Festpreis · Monatlich kündbar · Bodensee</span>
      <span class="text-lime">Erst sehen, dann zahlen →</span>
    </div>

    <div class="grid items-end gap-10 md:grid-cols-[1.15fr_1fr] md:gap-12">
      <div>
        <h1
          class="m-0 font-display text-[42px] leading-[0.9] font-black uppercase -tracking-[0.03em] text-bone sm:text-5xl md:text-[66px]"
        >
          Eine ganze<br />
          Marketing-<br />
          Abteilung.<br />
          <span class="bg-lime px-[10px] text-ink">zum <br />Minijob-Preis.</span>
        </h1>
        <p class="mt-7 max-w-[430px] text-base leading-[1.55] text-dim-2 md:text-[18px]">
          Content für alle Kanäle, jeden Monat zum Festpreis — monatlich kündbar, keine Setup-Fee. Und Sie sehen Ihre
          komplette Kampagne, bevor Sie einen Vertrag unterschreiben. KI-gestützt, von Hand freigegeben.
        </p>
        <div class="mt-9 flex w-fit flex-wrap border border-line">
          <a
            href="/vorschau"
            class="cursor-pointer bg-lime px-6 py-[17px] font-mono text-[13px] font-medium text-ink transition-colors hover:bg-bone"
          >
            Marketing-Vorschau kostenlos erstellen →
          </a>
          <a
            href="#funktioniert"
            class="cursor-pointer border-t border-line px-6 py-[17px] font-mono text-[13px] text-bone transition-colors hover:text-lime sm:border-t-0 sm:border-l"
          >
            Wie das läuft
          </a>
        </div>
      </div>

      <!-- Browser mockup -->
      <div class="border border-line bg-ink-2 shadow-[0_24px_50px_rgba(0,0,0,0.5)]">
        <div class="flex items-center gap-[7px] border-b border-line bg-ink-3 px-[14px] py-[11px]">
          <span class="size-2 bg-slate-mid"></span>
          <span class="size-2 bg-slate-mid"></span>
          <span class="ml-1.5 flex-1 font-mono text-[10px] text-dim truncate">
            immersive-markets.de/<span class="text-lime">mustermann-gmbh</span>
          </span>
        </div>
        <div class="p-5 md:p-[22px]">
          <div class="mb-4 flex items-center justify-between">
            <div class="font-mono text-[9px] tracking-[.12em] text-dim">IHRE VORSCHAU · IN 24H</div>
            <div class="font-mono text-[9px] text-lime">● BEREIT</div>
          </div>
          <div class="mb-4 font-display text-[22px] leading-none font-black uppercase -tracking-[0.03em] text-bone">
            Mustermann<br />
            <span class="bg-lime px-[5px] text-ink">GmbH</span>
          </div>
          <div class="mb-[9px] grid grid-cols-2 gap-[7px]">
            <div class="border border-line p-[10px]">
              <div class="mb-[7px] h-[6px] w-3/5 bg-lime"></div>
              <div class="mb-1 h-[3px] w-full bg-line"></div>
              <div class="h-[3px] w-3/4 bg-line"></div>
              <div class="mt-[9px] font-mono text-[8px] text-dim">LinkedIn</div>
            </div>
            <div class="border border-line p-[10px]">
              <div class="mb-[7px] h-[6px] w-[70%] bg-bone"></div>
              <div class="mb-1 h-[3px] w-full bg-line"></div>
              <div class="h-[3px] w-3/5 bg-line"></div>
              <div class="mt-[9px] font-mono text-[8px] text-dim">Instagram</div>
            </div>
          </div>
          <div class="border border-line p-[11px]">
            <div class="mb-[9px] font-mono text-[8px] tracking-[.1em] text-dim">CONTENT-KALENDER · KW 28</div>
            <div class="grid grid-cols-7 gap-1">
              <div class="h-[14px] bg-line"></div>
              <div class="h-[14px] bg-lime"></div>
              <div class="h-[14px] bg-line"></div>
              <div class="h-[14px] bg-line-deep"></div>
              <div class="h-[14px] bg-line"></div>
              <div class="h-[14px] bg-lime"></div>
              <div class="h-[14px] bg-line"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
