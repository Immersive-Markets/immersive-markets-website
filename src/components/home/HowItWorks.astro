---
---

<section id="funktioniert" class="bg-bone px-5 py-16 text-ink md:px-12 md:py-[88px]">
  <div class="mx-auto max-w-[1240px]">
    <div class="mb-10 flex flex-wrap items-end justify-between gap-4 md:mb-[52px]">
      <div>
        <div class="mb-3.5 font-mono text-[12px] uppercase tracking-[.16em] text-dim">So läuft es</div>
        <h2
          class="m-0 font-display text-[30px] leading-[0.95] font-black uppercase -tracking-[0.02em] sm:text-4xl md:text-[42px]"
        >
          Vom Link zur Vorschau<br />
          in drei Schritten.
        </h2>
      </div>
      <div class="max-w-[260px] font-mono text-[12px] leading-relaxed text-dim">
        Kostenlos, unverbindlich — Sie entscheiden erst danach.
      </div>
    </div>

    <div class="grid gap-[2px] border border-bone-3 bg-bone-3 md:grid-cols-3">
      <!-- Step 1 -->
      <div class="flex flex-col bg-bone p-8 md:p-[34px]">
        <div class="mb-6 flex items-baseline justify-between">
          <span class="font-display text-[44px] leading-none font-black -tracking-[0.03em]">01</span>
          <span class="font-mono text-[10px] tracking-widest text-dim">~2 MIN</span>
        </div>
        <div class="mb-2 text-[19px] font-bold">URL eingeben</div>
        <p class="mb-[22px] text-sm leading-relaxed text-dim-3">
          Ihre Website-Adresse, Name, E-Mail. Mehr braucht es nicht.
        </p>
        <div class="mt-auto border border-bone-3 bg-white p-[14px]">
          <div class="mb-2 font-mono text-[9px] text-dim">FIRMEN-URL</div>
          <div class="flex gap-1.5">
            <div class="flex-1 border border-bone-3 px-[10px] py-2 font-mono text-[11px] text-ink truncate">
              mustermann-gmbh.de
            </div>
            <div class="bg-ink px-3 py-2 font-mono text-[11px] text-lime">→</div>
          </div>
        </div>
      </div>

      <!-- Step 2 -->
      <div class="flex flex-col bg-bone p-8 md:p-[34px]">
        <div class="mb-6 flex items-baseline justify-between">
          <span class="font-display text-[44px] leading-none font-black -tracking-[0.03em]">02</span>
          <span class="font-mono text-[10px] tracking-widest text-dim">≤ 24 STD</span>
        </div>
        <div class="mb-2 text-[19px] font-bold">Ich baue Ihre Vorschau</div>
        <p class="mb-[22px] text-sm leading-relaxed text-dim-3">
          KI erstellt die Entwürfe, ich prüfe und schärfe jedes Stück.
        </p>
        <div class="mt-auto border border-bone-3 bg-white p-[14px]">
          <div class="mb-2.5 flex justify-between font-mono text-[9px] text-dim">
            <span>IN ARBEIT</span>
            <span class="text-line-deep">62%</span>
          </div>
          <div class="mb-3 h-1.5 bg-bone-2">
            <div class="h-1.5 w-[62%] bg-lime"></div>
          </div>
          <div class="flex flex-col gap-1.5 font-mono text-[10px] text-dim-3">
            <div>✓ Website ausgelesen</div>
            <div>✓ Tonalität erkannt</div>
            <div class="text-dim">▸ Entwürfe generieren</div>
          </div>
        </div>
      </div>

      <!-- Step 3 -->
      <div class="flex flex-col bg-bone p-8 md:p-[34px]">
        <div class="mb-6 flex items-baseline justify-between">
          <span class="font-display text-[44px] leading-none font-black -tracking-[0.03em]">03</span>
          <span class="font-mono text-[10px] tracking-widest text-dim">IN RUHE</span>
        </div>
        <div class="mb-2 text-[19px] font-bold">Anschauen, dann entscheiden</div>
        <p class="mb-[22px] text-sm leading-relaxed text-dim-3">
          Ihr fertiges Marketing in Ihrer CI. Gefällt es, starten wir.
        </p>
        <div class="mt-auto border border-bone-3 bg-ink p-[14px]">
          <div class="mb-2 font-mono text-[8px] tracking-[.1em] text-lime">● BEREIT</div>
          <div class="grid grid-cols-2 gap-[5px]">
            <div class="h-[34px] border border-line p-1.5">
              <div class="h-1 w-3/5 bg-lime"></div>
            </div>
            <div class="h-[34px] border border-line p-1.5">
              <div class="h-1 w-[70%] bg-bone"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-11 flex justify-center">
      <a
        href="/vorschau"
        class="cursor-pointer bg-ink px-7 py-4 font-mono text-[13px] text-bone transition-colors hover:bg-lime hover:text-ink"
      >
        Jetzt meine Vorschau anfordern →
      </a>
    </div>
  </div>
</section>
