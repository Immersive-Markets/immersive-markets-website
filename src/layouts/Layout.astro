---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Immersive Markets — Marketing als Handwerk, nicht als Agentur-Apparat",
  description =
    "Komplettes Marketing zum Festpreis, monatlich kündbar. Sehen Sie Ihre Kampagne, bevor Sie zahlen. KI-gestützt, von Hand freigegeben.",
} = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800;900&family=Martian+Mono:wght@400;500&display=swap"
    />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-ink text-bone">
    <slot />
  </body>
</html>
