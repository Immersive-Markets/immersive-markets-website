---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Immersive Markets — Marketing als Handwerk, nicht als Agentur-Apparat",
  description =
    "Komplettes Marketing zum Festpreis, monatlich kündbar. Sehen Sie Ihre Kampagne, bevor Sie zahlen. KI-gestützt, von Hand freigegeben.",
} = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800;900&family=Martian+Mono:wght@400;500&display=swap"
    />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-ink text-bone">
    <slot />

    <script>
      // Progressive enhancement for Web3Forms-backed forms.
      // Without JS, forms submit natively (POST + hidden `redirect`) and still work.
      document.querySelectorAll<HTMLFormElement>("form[data-web3form]").forEach((form) => {
        form.addEventListener("submit", async (e) => {
          // `submit` only fires after native HTML5 validation passes.
          e.preventDefault();

          const button = form.querySelector<HTMLButtonElement>('button[type="submit"]');
          const original = button?.textContent ?? "";
          if (button) {
            button.disabled = true;
            button.textContent = "Wird gesendet …";
          }

          const data = new FormData(form);
          // Per-form thank-you page + optional echo field (falls back to the
          // vorschau defaults so existing forms keep working unchanged).
          const danke = form.dataset.danke || "/vorschau/danke";
          const echoField = form.dataset.echo || "firma";
          const echo = String(data.get(echoField) ?? "");

          try {
            const res = await fetch("https://api.web3forms.com/submit", {
              method: "POST",
              headers: { Accept: "application/json" },
              body: data,
            });
            const json = await res.json();

            if (res.ok && json.success) {
              const query = echo ? `?${echoField}=${encodeURIComponent(echo)}` : "";
              window.location.href = `${danke}${query}`;
              return;
            }
            throw new Error(json.message || "Submission failed");
          } catch (err) {
            if (button) {
              button.disabled = false;
              button.textContent = original;
            }
            alert(
              "Ihre Anfrage konnte gerade nicht gesendet werden. Bitte versuchen Sie es erneut oder schreiben Sie an info@immersive-markets.de."
            );
          }
        });
      });
    </script>
  </body>
</html>
